FROM python:3.11-slim

ARG SERVICE_PORT=8010
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

RUN apt-get update && apt-get install -y --no-install-recommends ffmpeg build-essential && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY requirements.txt ./requirements.txt
RUN pip install --upgrade pip && pip install -r requirements.txt \
    && pip install openai-whisper transformers torch catboost pandas datasets seqeval

COPY app ./app
COPY examples ./examples

EXPOSE ${SERVICE_PORT}
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8010"]
